{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "dist/app.js",
  "type": "module",
  "engines": {
    "node": ">=18.19.0"
  },
  "scripts": {
    "build-clear": "rimraf dist.tmp tsconfig.tsbuildinfo",
    "build-tsc": "cross-env NODE_OPTIONS='--max-old-space-size=2048' tsc --project tsconfig.json --noEmit false --outDir dist.tmp --generateTrace ts-traces",
    "build-alias": "tsc-alias -p tsconfig.json --dir dist.tmp",
    "build-copy-html": "cross-env COPY_HTML_SRC=src COPY_HTML_DEST=dist.tmp node dist.tmp/misc/scripts/copyHtml.js",
    "build-swap": "node scripts/swap-dist.mjs",
    "build": "npm run build-clear && npm run build-tsc && npm run build-alias && npm run build-copy-html && npm run build-swap",
    "dev": "cross-env NODE_ENV=development tsx watch --inspect --trace-deprecation --max-old-space-size=1024 src/app.ts",
    "production": "cross-env NODE_ENV=production node --trace-warnings --trace-deprecation dist/app.js",
    "debug": "cross-env NODE_ENV=production MODE=debug node --inspect --max-old-space-size=2048 --expose-gc dist/app.js",
    "clean": "rimraf dist dist.tmp tsconfig.tsbuildinfo",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "migrate:undo:all": "sequelize-cli db:migrate:undo:all",
    "migrate:create": "sequelize-cli migration:create --name",
    "health": "cross-env tsx src/externalServices/healthService/startHealthService.ts",
    "health:prod": "cross-env NODE_ENV=production tsx src/externalServices/healthService/startHealthService.ts",
    "cdn": "cross-env tsx watch src/externalServices/cdnService/app.ts",
    "cdn:prod": "cross-env NODE_ENV=production tsx src/externalServices/cdnService/app.ts",
    "cdc": "cross-env tsx src/externalServices/cdcService/app.ts",
    "cdc:prod": "cross-env NODE_ENV=production tsx src/externalServices/cdcService/app.ts",
    "reconcile:es": "cross-env tsx src/misc/scripts/reconcileElasticsearch.ts",
    "backfill:leaderboard-ranks": "cross-env tsx src/misc/scripts/backfillLeaderboardRankHistory.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "gts lint",
    "fix": "gts fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@elastic/elasticsearch": "^9.0.1",
    "@google-cloud/recaptcha-enterprise": "^5.13.0",
    "@gumlet/gif-resize": "^2.0.0",
    "@types/cron": "^2.4.3",
    "@types/multer": "^1.4.12",
    "@types/socket.io": "^3.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript/analyze-trace": "^0.10.1",
    "@vlasky/zongji": "^0.6.1",
    "adofai-lib": "^1.2.8",
    "aws-sdk": "^2.1693.0",
    "axios": "^1.7.7",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cron": "^4.1.3",
    "cross-env": "^7.0.3",
    "discord-api-types": "^0.37.103",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "form-data": "^4.0.1",
    "iconv-lite": "^0.7.2",
    "json5": "^2.2.3",
    "jsonwebtoken": "^9.0.2",
    "mailersend": "^2.3.0",
    "multer": "1.4.5-lts.1",
    "music-metadata": "^11.12.3",
    "mysql2": "^3.11.5",
    "node-fetch": "^3.3.2",
    "nodemon": "^3.1.9",
    "object-hash": "^3.0.0",
    "punycode": "^2.3.0",
    "puppeteer": "^24.7.1",
    "redis": "^5.10.0",
    "sequelize": "^6.37.5",
    "sequelize-cli": "^6.6.2",
    "sharp": "^0.33.5",
    "socket": "^0.14.27",
    "socket.io": "^4.8.1",
    "stream-chain": "^3.6.1",
    "stream-json": "^2.1.0",
    "stripe": "^17.7.0",
    "swagger-ui-express": "^5.0.0",
    "twemoji": "^14.0.2",
    "uuid": "^11.0.3",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.5",
    "@types/nodemailer": "^6.4.17",
    "@types/object-hash": "^3.0.6",
    "@types/shuffle-seed": "^1.1.3",
    "@types/swagger-ui-express": "^4.1.6",
    "gts": "^6.0.2",
    "rimraf": "^5.0.5",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.7.0",
    "typescript": "~5.1.6"
  },
  "overrides": {
    "tmp": "^0.2.5",
    "minimatch": "^9.0.6"
  }
}
